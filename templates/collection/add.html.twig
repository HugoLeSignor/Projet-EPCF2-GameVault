{% extends 'base.html.twig' %}

{% block title %}Ajouter {{ game.titre }} - GameVault{% endblock %}

{% block body %}
    <div class="page-header">
        <h1 class="page-header__title">Ajouter à ma collection</h1>
    </div>

    <div class="card" style="max-width: 600px;">
        <h2>{{ game.titre }}</h2>
        <p class="text-muted">{{ game.plateforme }} - {{ game.genre }}</p>

        {{ form_start(form) }}
            {{ form_row(form.plateforme) }}
            {{ form_row(form.statut) }}
            {{ form_row(form.note) }}
            {{ form_row(form.tempsDeJeu) }}

            {{ form_row(form.commentaire) }}
            <div class="d-flex gap-sm mt-lg">
                <button type="submit" class="btn btn--primary">Ajouter à ma collection</button>
                <a href="{{ game.igdbId ? path('app_game_show', {igdbId: game.igdbId}) : path('app_game_show_local', {id: game.id}) }}" class="btn btn--outline">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
