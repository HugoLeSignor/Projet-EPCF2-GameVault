{% extends 'admin/_layout.html.twig' %}

{% block title %}Messages de contact - GameVault{% endblock %}

{% block admin_content %}
    <div class="page-header">
        <h1 class="page-header__title">Messages de contact{% if unreadCount > 0 %} <span class="badge badge--accent">{{ unreadCount }} non lu{{ unreadCount > 1 ? 's' : '' }}</span>{% endif %}</h1>
    </div>

    {% if messages|length > 0 %}
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th></th>
                        <th>Date</th>
                        <th>Nom</th>
                        <th>E-mail</th>
                        <th>Sujet</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for msg in messages %}
                        <tr class="{{ not msg.isRead ? 'admin-table__row--unread' : '' }}">
                            <td>
                                {% if not msg.isRead %}
                                    <span class="badge badge--accent badge--dot"></span>
                                {% endif %}
                            </td>
                            <td>{{ msg.createdAt|date('d/m/Y H:i') }}</td>
                            <td>{{ msg.nom }}</td>
                            <td><a href="mailto:{{ msg.email }}">{{ msg.email }}</a></td>
                            <td>{{ msg.sujet }}</td>
                            <td>
                                <div class="d-flex gap-sm">
                                    <a href="{{ path('admin_contact_show', {id: msg.id}) }}" class="btn btn--outline btn--sm">Voir</a>
                                    <form action="{{ path('admin_contact_delete', {id: msg.id}) }}" method="post" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ msg.id) }}">
                                        <button type="submit" class="btn btn--danger btn--sm" onclick="return confirm('Supprimer ce message ?')">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="empty-state">
            <div class="empty-state__icon">📭</div>
            <h3 class="empty-state__title">Aucun message</h3>
            <p class="empty-state__text">Aucun message de contact pour le moment.</p>
        </div>
    {% endif %}
{% endblock %}
