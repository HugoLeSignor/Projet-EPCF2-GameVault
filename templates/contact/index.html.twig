{% extends 'base.html.twig' %}

{% block title %}Contact - GameVault{% endblock %}

{% block body %}
    <div class="legal-page">
        <h1 class="legal-page__title">Nous contacter</h1>
        <p class="legal-page__intro">
            Une question, une suggestion ou un problème ? Envoyez-nous un message.
        </p>

        <div class="contact-info">
            <p>Vous pouvez aussi nous écrire directement à <a href="mailto:admin@gamevault.sc7duyo5958.universe.wf">admin@gamevault.sc7duyo5958.universe.wf</a></p>
        </div>

        {{ form_start(form, {'attr': {'class': 'contact-form'}}) }}
            <div class="form-group">
                {{ form_label(form.nom) }}
                {{ form_widget(form.nom, {'attr': {'class': 'form-input'}}) }}
                {{ form_errors(form.nom) }}
            </div>
            <div class="form-group">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-input'}}) }}
                {{ form_errors(form.email) }}
            </div>
            <div class="form-group">
                {{ form_label(form.sujet) }}
                {{ form_widget(form.sujet, {'attr': {'class': 'form-input'}}) }}
                {{ form_errors(form.sujet) }}
            </div>
            <div class="form-group">
                {{ form_label(form.message) }}
                {{ form_widget(form.message, {'attr': {'class': 'form-input'}}) }}
                {{ form_errors(form.message) }}
            </div>
            <button type="submit" class="btn btn--primary">Envoyer le message</button>
        {{ form_end(form) }}
    </div>
{% endblock %}
