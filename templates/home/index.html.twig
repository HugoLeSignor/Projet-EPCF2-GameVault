{% extends 'base.html.twig' %}

{% block title %}GameVault - Votre collection de jeux video{% endblock %}

{% block body %}
    {# ── Hero ── #}
    <section class="hero">
        <h1 class="hero__title">Votre univers gaming,<br><span class="hero__accent">au meme endroit.</span></h1>
        <p class="hero__subtitle">Suivez vos jeux, notez-les, partagez vos avis.</p>
        <form action="{{ path('app_game_index') }}" method="get" class="hero__search">
            <input type="text" name="q" placeholder="Rechercher un jeu..." class="hero__input" autocomplete="off">
            <button type="submit" class="btn btn--primary">Rechercher</button>
        </form>
    </section>

    {% if error %}
        <div class="alert alert--warning">{{ error }}</div>
    {% endif %}

    {# ── Reprendre (connected only) ── #}
    {% if inProgressEntries|length > 0 %}
        <section class="home-section">
            <div class="home-section__header">
                <h2 class="home-section__title">Reprendre</h2>
                <a href="{{ path('app_collection_index') }}" class="btn btn--outline btn--sm">Ma collection</a>
            </div>
            <div class="grid grid--3">
                {% for entry in inProgressEntries %}
                    <div class="game-card">
                        <a href="{{ entry.game.igdbId ? path('app_game_show', {igdbId: entry.game.igdbId}) : path('app_game_show_local', {id: entry.game.id}) }}">
                            {% if entry.game.imageFilename %}
                                <img src="{{ vich_uploader_asset(entry.game, 'imageFile') }}" alt="{{ entry.game.titre }}" class="game-card__image">
                            {% elseif entry.game.imageUrl %}
                                <img src="{{ entry.game.imageUrl }}" alt="{{ entry.game.titre }}" class="game-card__image">
                            {% else %}
                                <div class="game-card__placeholder">🎮</div>
                            {% endif %}
                        </a>
                        <div class="game-card__body">
                            <h3 class="game-card__title">
                                <a href="{{ entry.game.igdbId ? path('app_game_show', {igdbId: entry.game.igdbId}) : path('app_game_show_local', {id: entry.game.id}) }}">{{ entry.game.titre }}</a>
                            </h3>
                            <div class="game-card__meta">
                                <span class="game-card__tag">En cours</span>
                                {% if entry.tempsDeJeu %}
                                    <span class="game-card__tag">{{ entry.tempsDeJeuFormatted }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {# ── Jeux populaires ── #}
    {% if popularGames|length > 0 %}
        <section class="home-section">
            <div class="home-section__header">
                <h2 class="home-section__title">Jeux populaires</h2>
                <a href="{{ path('app_game_index') }}" class="btn btn--outline btn--sm">Voir tout</a>
            </div>
            <div class="grid grid--4">
                {% for game in popularGames %}
                    <div class="game-card">
                        <a href="{{ path('app_game_show', {igdbId: game.igdbId}) }}">
                            {% if game.coverUrl %}
                                <img src="{{ game.coverUrl }}" alt="{{ game.name }}" class="game-card__image">
                            {% else %}
                                <div class="game-card__placeholder">🎮</div>
                            {% endif %}
                        </a>
                        <div class="game-card__body">
                            <h3 class="game-card__title">
                                <a href="{{ path('app_game_show', {igdbId: game.igdbId}) }}">{{ game.name }}</a>
                            </h3>
                            <div class="game-card__meta">
                                <span class="game-card__tag">{{ game.platform }}</span>
                                <span class="game-card__tag">{{ game.genre }}</span>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {# ── Sorties recentes ── #}
    {% if recentReleases|length > 0 %}
        <section class="home-section">
            <div class="home-section__header">
                <h2 class="home-section__title">Sorties recentes</h2>
                <a href="{{ path('app_game_index') }}" class="btn btn--outline btn--sm">Voir tout</a>
            </div>
            <div class="grid grid--4">
                {% for game in recentReleases %}
                    <div class="game-card">
                        <a href="{{ path('app_game_show', {igdbId: game.igdbId}) }}">
                            {% if game.coverUrl %}
                                <img src="{{ game.coverUrl }}" alt="{{ game.name }}" class="game-card__image">
                            {% else %}
                                <div class="game-card__placeholder">🎮</div>
                            {% endif %}
                        </a>
                        <div class="game-card__body">
                            <h3 class="game-card__title">
                                <a href="{{ path('app_game_show', {igdbId: game.igdbId}) }}">{{ game.name }}</a>
                            </h3>
                            <div class="game-card__meta">
                                <span class="game-card__tag">{{ game.platform }}</span>
                                {% if game.releaseDate %}
                                    <span class="game-card__tag">{{ game.releaseDate|date('d/m/Y') }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {# ── Explorer par genre ── #}
    <section class="home-section">
        <div class="home-section__header">
            <h2 class="home-section__title">Explorer par genre</h2>
        </div>
        {% set genreEmojis = {
            'Action': '⚔️',
            'Aventure': '🗺️',
            'RPG': '🐉',
            'FPS': '🎯',
            'Strategie': '♟️',
            'Sport': '⚽',
            'Course': '🏎️',
            'Simulation': '🛩️',
            'Puzzle': '🧩',
            'Plateforme': '🍄',
            'Horreur': '👻',
            'Indie': '🎨'
        } %}
        <div class="genre-grid">
            {% for genre in genres %}
                <a href="{{ path('app_game_index', {genre: genre}) }}" class="genre-card">
                    <span class="genre-card__emoji">{{ genreEmojis[genre] ?? '🎮' }}</span>
                    <span class="genre-card__name">{{ genre }}</span>
                </a>
            {% endfor %}
        </div>
    </section>

    {# ── CTA for guests ── #}
    {% if not app.user %}
        <section class="home-cta">
            <h2>Pret a commencer ?</h2>
            <p>Creez votre compte et commencez a suivre vos jeux.</p>
            <a href="{{ path('app_register') }}" class="btn btn--primary btn--lg">Creer un compte</a>
        </section>
    {% endif %}
{% endblock %}
