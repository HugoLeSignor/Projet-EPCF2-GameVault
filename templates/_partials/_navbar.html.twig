<nav class="navbar">
    <div class="navbar__container">
        <a href="{{ path('app_home') }}" class="navbar__brand">GameVault</a>

        <button class="navbar__burger" aria-label="Menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <div class="navbar__collapse">
            <ul class="navbar__menu">
                <li><a href="{{ path('app_game_index') }}" class="navbar__link{% if app.request.attributes.get('_route') starts with 'app_game' %} navbar__link--active{% endif %}">Catalogue</a></li>
                <li><a href="{{ path('app_users') }}" class="navbar__link{% if app.request.attributes.get('_route') starts with 'app_user' %} navbar__link--active{% endif %}">Communauté</a></li>
                {% if is_granted('ROLE_USER') %}
                    <li><a href="{{ path('app_collection_index') }}" class="navbar__link{% if app.request.attributes.get('_route') starts with 'app_collection' %} navbar__link--active{% endif %}">Ma Collection</a></li>
                {% endif %}
                {% if is_granted('ROLE_ADMIN') %}
                    <li><a href="{{ path('admin_dashboard') }}" class="navbar__link navbar__link--admin{% if app.request.attributes.get('_route') starts with 'admin_' %} navbar__link--active{% endif %}">Admin</a></li>
                {% endif %}
            </ul>

            <div class="navbar__auth">
                {% if app.user %}
                    <a href="{{ path('app_notifications') }}" class="navbar__notif{% if app.request.attributes.get('_route') starts with 'app_notification' %} navbar__notif--active{% endif %}" title="Notifications">
                        🔔
                        {% if unreadNotifCount is defined and unreadNotifCount > 0 %}
                            <span class="navbar__badge">{{ unreadNotifCount }}</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_profile') }}" class="navbar__avatar-link" title="Mon profil">
                        {% if app.user.avatarFilename %}
                            <img src="{{ vich_uploader_asset(app.user, 'avatarFile') }}" alt="{{ app.user.pseudo }}" class="navbar__avatar">
                        {% else %}
                            <span class="navbar__avatar navbar__avatar--placeholder">{{ app.user.pseudo|first|upper }}</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_logout') }}" class="btn btn--outline btn--sm">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn btn--outline btn--sm">Connexion</a>
                    <a href="{{ path('app_register') }}" class="btn btn--primary btn--sm">Inscription</a>
                {% endif %}
            </div>
        </div>
    </div>
</nav>
