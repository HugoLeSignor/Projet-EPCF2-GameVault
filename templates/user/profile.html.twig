{% extends 'base.html.twig' %}

{% block title %}{{ profileUser.pseudo }} - GameVault{% endblock %}

{% block body %}
    {# ── Banner + Avatar ── #}
    <div class="profile-banner">
        {% if profileUser.bannerFilename %}
            <img src="{{ vich_uploader_asset(profileUser, 'bannerFile') }}" alt="" class="profile-banner__image">
        {% endif %}
        <div class="profile-banner__overlay"></div>
    </div>

    <div class="profile-hero">
        <div class="profile-hero__avatar">
            {% if profileUser.avatarFilename %}
                <img src="{{ vich_uploader_asset(profileUser, 'avatarFile') }}" alt="{{ profileUser.pseudo }}">
            {% else %}
                <span>{{ profileUser.pseudo|first|upper }}</span>
            {% endif %}
        </div>

        <div class="profile-hero__info">
            <div class="profile-hero__top">
                <h1 class="profile-hero__name">{{ profileUser.pseudo }}</h1>
                {% if app.user and app.user != profileUser %}
                    <form action="{{ path('app_user_follow', {id: profileUser.id}) }}" method="post" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('follow' ~ profileUser.id) }}">
                        {% if isFollowing %}
                            <button type="submit" class="btn btn--outline btn--sm">Ne plus suivre</button>
                        {% else %}
                            <button type="submit" class="btn btn--primary btn--sm">Suivre</button>
                        {% endif %}
                    </form>
                {% endif %}
            </div>
            <div class="profile-hero__follow-stats">
                <span><strong>{{ followersCount }}</strong> abonne{{ followersCount > 1 ? 's' : '' }}</span>
                <span><strong>{{ followingCount }}</strong> abonnement{{ followingCount > 1 ? 's' : '' }}</span>
            </div>
            {% if profileUser.bio %}
                <p class="profile-hero__bio">{{ profileUser.bio }}</p>
            {% endif %}
            <p class="profile-hero__joined">Membre depuis {{ profileUser.createdAt|date('M Y') }}</p>
        </div>
    </div>

    {# ── Stats Overview ── #}
    <div class="profile-stats-bar">
        <div class="profile-stats-bar__item">
            <span class="profile-stats-bar__value">{{ stats.totalGames }}</span>
            <span class="profile-stats-bar__label">Total jeux</span>
        </div>
        <div class="profile-stats-bar__item">
            <span class="profile-stats-bar__value">{{ stats.daysPlayed }}</span>
            <span class="profile-stats-bar__label">Jours joués</span>
        </div>
        <div class="profile-stats-bar__item">
            <span class="profile-stats-bar__value">{{ stats.averageRating ?? '-' }}<small>/10</small></span>
            <span class="profile-stats-bar__label">Note moyenne</span>
        </div>
        <div class="profile-stats-bar__item">
            <span class="profile-stats-bar__value">{{ stats.finishedGames }}</span>
            <span class="profile-stats-bar__label">Terminés</span>
        </div>
        <div class="profile-stats-bar__item">
            <span class="profile-stats-bar__value">{{ stats.reviewCount }}</span>
            <span class="profile-stats-bar__label">Avis</span>
        </div>
    </div>

    {# ── Status Distribution Bar ── #}
    {% if stats.totalGames > 0 %}
        <div class="status-segment">
            <div class="status-segment__bar">
                {% for status, count in stats.statusDistribution %}
                    {% if count > 0 %}
                        <div class="status-segment__fill status-segment__fill--{{ status }}"
                             style="width: {{ (count / stats.totalGames * 100) }}%"
                             title="{{ count }}">
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
            <div class="status-segment__legend">
                {% for status, count in stats.statusDistribution %}
                    {% if count > 0 %}
                        <span class="status-segment__item">
                            <span class="status-segment__dot status-segment__dot--{{ status }}"></span>
                            {{ count }}
                        </span>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# ── Genre & Platform Distribution ── #}
    {% if stats.genreDistribution|length > 0 or stats.platformDistribution|length > 0 %}
        <div class="profile-distributions">
            {% if stats.genreDistribution|length > 0 %}
                <div class="profile-distrib-card">
                    <h3 class="profile-distrib-card__title">Genres</h3>
                    {% for genre, count in stats.genreDistribution %}
                        <div class="profile-distrib-card__row">
                            <span class="profile-distrib-card__label">{{ genre }}</span>
                            <div class="profile-distrib-card__track">
                                <div class="profile-distrib-card__fill" style="width: {{ (count / stats.totalGames * 100)|round }}%"></div>
                            </div>
                            <span class="profile-distrib-card__count">{{ count }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            {% if stats.platformDistribution|length > 0 %}
                <div class="profile-distrib-card">
                    <h3 class="profile-distrib-card__title">Plateformes</h3>
                    {% for platform, count in stats.platformDistribution %}
                        <div class="profile-distrib-card__row">
                            <span class="profile-distrib-card__label">{{ platform }}</span>
                            <div class="profile-distrib-card__track">
                                <div class="profile-distrib-card__fill" style="width: {{ (count / stats.totalGames * 100)|round }}%"></div>
                            </div>
                            <span class="profile-distrib-card__count">{{ count }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    {% endif %}

    {# ── Full Collection (AniList-style grouped tables) ── #}
    {% if collectionByStatus|length > 0 %}
        {% for group in collectionByStatus %}
            <section class="profile-collection-group">
                <div class="profile-collection-group__header profile-collection-group__header--{{ group.status.value }}">
                    <h2 class="profile-collection-group__title">{{ group.status.label }}</h2>
                    <span class="profile-collection-group__count">{{ group.entries|length }}</span>
                </div>

                <table class="profile-collection-table">
                    <thead>
                        <tr>
                            <th class="profile-collection-table__th-title">Titre</th>
                            <th class="profile-collection-table__th-score">Note</th>
                            <th class="profile-collection-table__th-progress">Progression</th>
                            <th class="profile-collection-table__th-platform">Plateforme</th>
                            <th class="profile-collection-table__th-time">Temps</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for entry in group.entries %}
                            <tr class="profile-collection-table__row">
                                <td class="profile-collection-table__cell-title">
                                    <a href="{{ entry.game.igdbId ? path('app_game_show', {igdbId: entry.game.igdbId}) : path('app_game_show_local', {id: entry.game.id}) }}" class="profile-collection-table__game-link">
                                        {% if entry.game.imageUrl %}
                                            <img src="{{ entry.game.imageUrl }}" alt="" class="profile-collection-table__cover">
                                        {% elseif entry.game.imageFilename %}
                                            <img src="{{ vich_uploader_asset(entry.game, 'imageFile') }}" alt="" class="profile-collection-table__cover">
                                        {% else %}
                                            <div class="profile-collection-table__cover-placeholder"></div>
                                        {% endif %}
                                        <span>{{ entry.game.titre }}</span>
                                    </a>
                                </td>
                                <td class="profile-collection-table__cell-score">
                                    {% if entry.note %}
                                        <span class="profile-collection-table__score">{{ entry.note }}</span>
                                    {% else %}
                                        <span class="profile-collection-table__score--empty">-</span>
                                    {% endif %}
                                </td>
                                <td class="profile-collection-table__cell-progress">
                                    {% if entry.progression %}
                                        {{ entry.progression }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td class="profile-collection-table__cell-platform">
                                    {{ entry.game.plateforme ?? '-' }}
                                </td>
                                <td class="profile-collection-table__cell-time">
                                    {{ entry.tempsDeJeuFormatted }}
                                </td>
                            </tr>
                            {% if entry.commentaire %}
                                <tr class="profile-collection-table__comment-row">
                                    <td colspan="5">
                                        <div class="profile-collection-table__comment">
                                            {{ entry.commentaire }}
                                        </div>
                                    </td>
                                </tr>
                            {% endif %}
                        {% endfor %}
                    </tbody>
                </table>
            </section>
        {% endfor %}
    {% endif %}
{% endblock %}
