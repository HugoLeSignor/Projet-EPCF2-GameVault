{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - GameVault{% endblock %}

{% block body %}
    <div class="auth-form">
        <div class="auth-form__card">
            <h1 class="auth-form__title">Mot de passe oublié</h1>

            <p class="auth-form__description">
                Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.
            </p>

            {{ form_start(requestForm) }}
                {{ form_row(requestForm.email) }}

                <button type="submit" class="btn btn--primary btn--block">Envoyer le lien</button>
            {{ form_end(requestForm) }}

            <div class="auth-form__footer">
                <p><a href="{{ path('app_login') }}">Retour à la connexion</a></p>
            </div>
        </div>
    </div>
{% endblock %}
